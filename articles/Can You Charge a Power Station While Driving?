  <thead>
    <tr>
      <th>Method</th>
      <th>Max Watts</th>
      <th>Time to Fill 1,000Wh</th>
    </tr>
  </thead>
  <tbody>
    <tr>
      <td>Cigarette lighter</td>
      <td>100–130W</td>
      <td class="loser">8–10 hours</td>
    </tr>
    <tr>
      <td>Direct-to-battery cable</td>
